amends "@pkl.impl.ghactions/PklCI.pkl"

import "@com.github.actions/catalog.pkl"
import "@com.github.actions/context.pkl"
import "@com.github.actions/Workflow.pkl"
import "@pkl.impl.ghactions/helpers.pkl"

local buildArtifactsName = "pkl-lsp-build-artifacts"

testReports {
  junit {
    "build/test-results/**/*.xml"
  }
  excludeJobs {
    Regex("deploy-.*")
    "dependency-submission"
  }
}

local JAVA_VERSION = "25"

local baseSetupJava = (catalog.`actions/setup-java@v5`) {
  with {
    `java-version` = JAVA_VERSION
    distribution = "temurin"
  }
}

local function buildJob(isRelease: Boolean): Workflow.Job = new {
  `runs-on` = "ubuntu-latest"
  steps {
    (catalog.`actions/checkout@v6`) {
      with {
        `fetch-depth` = 0 // needed for spotless
      }
    }
    (baseSetupJava) {
      with {
        cache = if (isRelease) null else "gradle"
      }
    }
    new {
      `if` = "github.repository != 'apple/pkl-lsp'"
      run =
        """
        git remote add upstream https://github.com/apple/pkl-lsp.git
        git fetch upstream main
        echo 'PKL_ORIGINAL_REMOTE_NAME=upstream' > "$GITHUB_ENV"
        """
    }
    new {
      name = "Set DEBUG_ARGS env var"
      env {
        ["RUNNER_DEBUG"] = context.runner.debug
      }
      shell = "bash"
      // language=bash
      run =
        """
        if [[ "$RUNNER_DEBUG" -eq 1 ]]; then
          echo "DEBUG_ARGS=--info --stacktrace" >> $GITHUB_ENV
        fi
        """
    }
    new {
      local args: Listing<String> = new {
        "$DEBUG_ARGS"
        when (isRelease) {
          "-DreleaseBuild=true"
        }
      }
      run =
        """
        ./gradlew \(args.join(" ")) check shadowJar verifyDistribution
        """
    }
    (catalog.`actions/upload-artifact@v5`) {
      name = "Upload build artifacts"
      `if` = "!cancelled()"
      with {
        name = buildArtifactsName
        // Need to insert a wildcard to make actions/upload-artifact preserve the folder hierarchy.
        // See https://github.com/actions/upload-artifact/issues/206
        path = "build*/libs/"
      }
    }
  }
}

local function verifyJobs(requiresJob: String): Mapping<String, Workflow.Job> = new {
  default {
    needs { requiresJob }
    steps {
      (catalog.`actions/checkout@v6`) {}
      (baseSetupJava) {
        with {
          cache = if (requiresJob.contains("release")) null else "gradle"
        }
      }
      (catalog.`actions/download-artifact@v6`) {
        with {
          name = "build-jar"
          path = "build/libs/"
        }
      }
      new {
        name = "Set DEBUG_ARGS env var"
        env {
          ["RUNNER_DEBUG"] = context.runner.debug
        }
        shell = "bash"
        // language=bash
        run =
          """
          if [[ "$RUNNER_DEBUG" -eq 1 ]]; then
            echo "DEBUG_ARGS=--info --stacktrace" >> $GITHUB_ENV
          fi
          """
      }
      new {
        run =
          """
          ./gradlew "$DEBUG_ARGS" verifyDistribution
          """
      }
    }
  }
  ["test-macos"] {
    `runs-on` = new Listing { "self-hosted"; "macos" }
    `if` = "github.repository_owner == 'apple'"
  }
  ["test-windows"] {
    `runs-on` = "windows-latest"
  }
}

local verifyJobNames = verifyJobs("build").keys.toListing()

local baseMavenDeploy: Workflow.Job = new {
  `runs-on` = "ubuntu-latest"
  environment = "maven-release"
  steps {
    (catalog.`actions/checkout@v6`) {}
    baseSetupJava
    (catalog.`actions/download-artifact@v6`) {
      with {
        name = buildArtifactsName
        path = "build/libs/"
      }
    }
  }
}

// --- Native executable build jobs ---

local function nativeBuildJob(os: String, arch: String, isRelease: Boolean): Workflow.Job = new {
  `runs-on` =
    if (os == "linux" && arch == "amd64")
      "ubuntu-latest"
    else if (os == "linux" && arch == "aarch64")
      "ubuntu-24.04-arm"
    else if (os == "windows")
      "windows-latest"
    else
      new Listing { "self-hosted"; "macos" }

  when (os == "macos") {
    `if` = "github.repository_owner == 'apple'"
  }

  when (os == "linux") {
    container {
      image = "redhat/ubi8:8.10"
    }
  }

  steps {
    (catalog.`actions/checkout@v6`) {
      with {
        `fetch-depth` = 0
      }
    }
    (baseSetupJava) {
      with {
        cache = if (isRelease) null else "gradle"
      }
    }
    when (os == "linux") {
      new {
        name = "Install deps"
        run =
          "dnf install -y git binutils gcc glibc-devel zlib-devel libstdc++-static glibc-langpack-en xz"
      }
    }
    new {
      name = "Set DEBUG_ARGS env var"
      env {
        ["RUNNER_DEBUG"] = context.runner.debug
      }
      shell = "bash"
      // language=bash
      run =
        """
        if [[ "$RUNNER_DEBUG" -eq 1 ]]; then
          echo "DEBUG_ARGS=--info --stacktrace" >> $GITHUB_ENV
        fi
        """
    }
    new {
      name = "Build native executable"
      shell = "bash"
      local gradleArgs: Listing<String> = new {
        "$DEBUG_ARGS"
        when (isRelease) {
          "-DreleaseBuild=true"
        }
      }
      run = "./gradlew \(gradleArgs.join(" ")) buildNative"
    }
    (catalog.`actions/upload-artifact@v5`) {
      name = "Upload native executable"
      `if` = "!cancelled()"
      with {
        name = "build-native-\(os)-\(arch)"
        // Need to insert a wildcard to make actions/upload-artifact preserve the folder hierarchy.
        // See https://github.com/actions/upload-artifact/issues/206
        path = "build*/executable/*"
      }
    }
  }
}

local nativeJobNames: Listing<String> = new {
  "native-macos-aarch64"
  "native-linux-amd64"
  "native-linux-aarch64"
  "native-windows-amd64"
}

local nativeReleaseJobs: Mapping<String, Workflow.Job> = new {
  ["native-macos-aarch64"] = nativeBuildJob("macos", "aarch64", false)
  ["native-linux-amd64"] = nativeBuildJob("linux", "amd64", false)
  ["native-linux-aarch64"] = nativeBuildJob("linux", "aarch64", false)
  ["native-windows-amd64"] = nativeBuildJob("windows", "amd64", false)
}

local function nativePrbTags(os: String, arch: String): String =
  new Listing {
    "[native]"
    "[native-\(os)]"
    "[native-\(os)-\(arch)]"
  }
    .toList()
    .map((tag) -> "contains(github.event.pull_request.body, '\(tag)')")
    .join(" || ")

local function nativePrbIf(os: String, arch: String): String =
  if (os == "macos")
    "(\(nativePrbTags(os, arch))) && github.repository_owner == 'apple'"
  else
    nativePrbTags(os, arch)

local nativePrbJobs: Mapping<String, Workflow.Job> = new {
  ["native-macos-aarch64"] = (nativeBuildJob("macos", "aarch64", false)) {
    `if` = nativePrbIf("macos", "aarch64")
  }
  ["native-linux-amd64"] = (nativeBuildJob("linux", "amd64", false)) {
    `if` = nativePrbIf("linux", "amd64")
  }
  ["native-linux-aarch64"] = (nativeBuildJob("linux", "aarch64", false)) {
    `if` = nativePrbIf("linux", "aarch64")
  }
  ["native-windows-amd64"] = (nativeBuildJob("windows", "amd64", false)) {
    `if` = nativePrbIf("windows", "amd64")
  }
}

prb {
  jobs {
    ["build"] = buildJob(false)
    ...nativePrbJobs
  }
}

build {
  jobs {
    ["build"] = buildJob(false)
    ...(verifyJobs("build")) {
    // TODO use lower priority runners for on-push macOS jobs
    // ["test-macos"] { `runs-on` { "nightly" } }
    }
  }
}

releaseBranch = build

main = (build) {
  jobs {
    ["deploy-maven-snapshot"] = (baseMavenDeploy) {
      needs = verifyJobNames
      steps {
        new Workflow.Step {
          name = "Publish snapshot release"
          run = "./gradlew publishToSonatype"
        } |> helpers.withMavenPublishSecrets
      }
    }
    ["dependency-submission"] {
      `runs-on` = "ubuntu-latest"
      permissions {
        contents = "write"
      }
      steps {
        module.catalog.`actions/checkout@v6`
        baseSetupJava
        (module.catalog.`gradle/actions/dependency-submission@v6`) {
          with {
            // language=regexp
            `dependency-graph-include-configurations` =
              ".*[rR]untimeClasspath|.*[cC]ompileClasspath"
          }
        }
      }
    }
  }
}

release {
  jobs {
    ["build-release"] = buildJob(true)
    ...verifyJobs("build-release")
    ...nativeReleaseJobs
    // do GitHub release first because we can overwrite the tag.
    // publishing to Maven Central is final.
    ["deploy-github-release"] {
      `runs-on` = "ubuntu-latest"
      needs = new {
        ...verifyJobs("build-release").keys.toListing()
        ...nativeJobNames
      }
      permissions {
        contents = "write"
      }
      steps {
        (catalog.`actions/download-artifact@v6`) {
          with {
            pattern = "build-**"
            `merge-multiple` = true
          }
        }
        new {
          name = "Publish release to GitHub"
          env {
            ["GH_TOKEN"] = context.github.token
            ["GH_REPO"] = context.github.repository
            ["VERSION"] = context.github.refName
          }
          run =
            #"""
            # exclude build_artifacts.txt from publish
            rm -f */build/executable/*.build_artifacts.txt
            find */build/executable/* -type d | xargs rm -rf
            gh release create "${VERSION}" \
              --title "${VERSION}" \
              --verify-tag \
              --notes "Release notes: https://pkl-lang.org/lsp/current/CHANGELOG.html#release-${VERSION}" \
              build/libs/* build/executable/*
            """#
        }
      }
    }
    ["deploy-maven-release"] = (baseMavenDeploy) {
      needs { "deploy-github-release" }
      steps {
        new Workflow.Step {
          name = "Publish to Maven Central"
          run =
            // language=bash
            """
            ./gradlew -DreleaseBuild=true publishToSonatype closeAndReleaseSonatypeStagingRepository
            """
        } |> helpers.withMavenPublishSecrets
      }
    }
  }
}

dependabot {
  updates {
    new {
      `package-ecosystem` = "gradle"
      directory = "/"
      cooldown {
        `default-days` = 7
        exclude {
          "org.pkl-lang"
        }
      }
      schedule {
        interval = "quarterly"
      }
    }
  }
}

codeql {
  scans {
    new {
      language = "java-kotlin"
      buildMode = "autobuild"
    }
  }
}
